# ─────────────────────────────────────────────
# 이 파일을 복사해 .env 로 이름 바꾼 후 값을 채워주세요
# cp .env.example .env
# ─────────────────────────────────────────────

# ── Anthropic Claude API Key ──────────────────
# https://console.anthropic.com 에서 발급
VITE_ANTHROPIC_API_KEY=sk-ant-...

# ── Google Sheets 연동 ────────────────────────
# 서버사이드 변수 (VITE_ 접두사 없음)
# 프로덕션: Vercel 대시보드 > Settings > Environment Variables 에 직접 입력
# 개발:     vercel dev 명령어 사용 시 이 파일의 값이 자동 적용됨
#           (npm run dev 는 /api/sheets 엔드포인트를 처리하지 못하므로
#            Google Sheets 미연결 → localStorage에만 저장됨)
#
# [서비스 계정 설정 방법]
# 1. https://console.cloud.google.com 에서 프로젝트 생성
# 2. Google Sheets API 활성화
# 3. IAM > 서비스 계정 생성 > JSON 키 발급
# 4. 대상 스프레드시트에서 서비스 계정 이메일을 편집자로 공유
# 5. 스프레드시트에 'News', 'NewsKeywords' 시트 탭 생성

# 스프레드시트 URL의 /d/XXXXXX/ 부분
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# 서비스 계정 이메일
GOOGLE_SERVICE_ACCOUNT_EMAIL=bio-briefing@your-project.iam.gserviceaccount.com

# JSON 키 파일의 "private_key" 값 그대로 붙여넣기 (\n 포함)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----
