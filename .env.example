# ─────────────────────────────────────────────
# 이 파일을 복사해 .env 로 이름 바꾼 후 값을 채워주세요
# cp .env.example .env
# ─────────────────────────────────────────────

# ── Anthropic Claude API Key ──────────────────
# https://console.anthropic.com 에서 발급
VITE_ANTHROPIC_API_KEY=sk-ant-...

# ── Google Sheets 연동 — Apps Script 웹 앱 URL ─
# Google Apps Script 편집기에서 배포 > 웹 앱으로 배포 후 받은 URL 입력
# 별도 인증 키 불필요 (Apps Script가 인증 처리)
VITE_SHEETS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
